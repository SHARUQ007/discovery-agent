# Local bridge server
PORT=8787
OLLAMA_BASE_URL=http://localhost:11434

# Google Sheets database for Remote AI mode
# Share the target Google Sheet with GOOGLE_SERVICE_ACCOUNT_EMAIL as Editor.
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id_here
GOOGLE_SHEETS_SHEET_NAME=StructuredDiscoveryRuns
