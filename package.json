{
  "name": "structured-discovery-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "worker": "node server/worker.js",
    "ollama:serve": "node server/ollamaRunner.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "dev:ai": "concurrently --kill-others \"npm run ollama:serve\" \"npm run worker\" \"npm run dev:all\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
